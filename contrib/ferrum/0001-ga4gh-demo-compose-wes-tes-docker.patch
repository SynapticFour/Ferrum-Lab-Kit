diff --git a/demo/docker-compose.ga4gh.yml b/demo/docker-compose.ga4gh.yml
new file mode 100644
index 00000000..03d45659
--- /dev/null
+++ b/demo/docker-compose.ga4gh.yml
@@ -0,0 +1,44 @@
+# GA4GH local overlay: WES workdir on host-visible paths, TES via Docker (Bollard),
+# optional Crypt4GH keys, nested-engine networking.
+#
+# Requires gateway built with Bollard: build arg FERRUM_GATEWAY_FEATURES=tes-docker (set below).
+#
+#   export FERRUM_WES_WORK_HOST=/absolute/path/wes-runs
+#   export FERRUM_TES_WORK_HOST=/absolute/path/tes-jobs
+#   mkdir -p "$FERRUM_WES_WORK_HOST" "$FERRUM_TES_WORK_HOST"
+#   docker compose -p ferrum-ga4gh -f deploy/docker-compose.yml -f demo/docker-compose.ga4gh.yml up -d --build
+#
+# Naming:
+#   * FERRUM_WES_WORK_HOST / FERRUM_TES_WORK_HOST — host paths for Compose bind mounts only (not read by Rust).
+#   * FERRUM_WES_WORK_DIR / FERRUM_TES_WORK_DIR — in-container paths (must match mount targets).
+#   * Never use the typo FERUM_WES_WORK_HOST (missing R).
+#
+# TES Docker env reference: docs/TES-DOCKER-BACKEND.md
+
+name: ferrum-ga4gh
+
+services:
+  ferrum-gateway:
+    build:
+      args:
+        FERRUM_GATEWAY_FEATURES: tes-docker
+    environment:
+      FERRUM_PUBLIC_BASE_URL: ${FERRUM_PUBLIC_BASE_URL:-http://localhost:8080}
+      FERRUM_WES_WORK_DIR: /wes-runs
+      FERRUM_WES_TES_URL: http://ferrum-gateway:8080/ga4gh/tes/v1
+      # Inject symmetric host bind into WES→TES tasks (same path on host and in task)
+      FERRUM_WES_TES_WORK_HOST_PREFIX: ${FERRUM_WES_WORK_HOST}
+      FERRUM_TES_BACKEND: docker
+      FERRUM_TES_WORK_DIR: /tes-jobs
+      FERRUM_TES_DOCKER_NETWORK_MODE: ferrum-ga4gh_default
+      FERRUM_TES_DOCKER_EXTRA_HOSTS: host.docker.internal:host-gateway
+      # Add docker.sock into each TES task (nested docker); gateway still mounts sock below for Bollard
+      FERRUM_TES_DOCKER_MOUNT_SOCKET: "1"
+      FERRUM_ENCRYPTION__CRYPT4GH_KEY_DIR: ${FERRUM_ENCRYPTION__CRYPT4GH_KEY_DIR:-/etc/ferrum/crypt4gh-keys}
+    volumes:
+      - ${FERRUM_WES_WORK_HOST:?}:/wes-runs
+      - ${FERRUM_TES_WORK_HOST:?}:/tes-jobs
+      - /var/run/docker.sock:/var/run/docker.sock
+      - ${FERRUM_CRYPT4GH_KEY_HOST_DIR:-./var/ferrum-crypt4gh-keys}:${FERRUM_ENCRYPTION__CRYPT4GH_KEY_DIR:-/etc/ferrum/crypt4gh-keys}:ro
+    extra_hosts:
+      - "host.docker.internal:host-gateway"
